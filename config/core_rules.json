{
  "display_as_rules": [
    {
      "match": "White",
      "display_as": "White or Caucasian",
      "exact_match": true,
      "columns": ["Race"]
    },
    {
      "match": "Treatment naive",
      "display_as": "Not treated",
      "exact_match": true,
      "columns": ["Treatment Status"]
    }
  ],
  "alert_rules": [
    {
      "column": "Stage",
      "condition": "is_empty",
      "message": "Missing Stage"
    },
    {
      "column": "Date/time of operation",
      "condition": "column_before",
      "compare_column": "Date/time of blood collection",
      "message": "Operation date/time is before blood collection date/time."
    }
  ]
}
